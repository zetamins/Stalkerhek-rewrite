#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: GPL-2.0-only
#
# Stalkerhek IPTV middleware for OpenWrt
# Install: cp this file to /etc/init.d/stalkerhek, then:
#   chmod +x /etc/init.d/stalkerhek
#   /etc/init.d/stalkerhek enable
#   /etc/init.d/stalkerhek start
#
# The binary and data live on a USB drive at the path below.
# Adjust USB_PATH to match your setup.

USE_PROCD=1
START=99

USB_PATH="/mnt/usb"
STALKERHEK_DIR="${USB_PATH}/stalkerhek"
BIN="${STALKERHEK_DIR}/stalkerhek"
DATA_DIR="${STALKERHEK_DIR}/data"

start_service() {
  if [ ! -f "$BIN" ]; then
    echo "Stalkerhek binary not found at $BIN"
    echo "Make sure the USB drive is mounted at $USB_PATH"
    return 1
  fi

  # Ensure USB is mounted
  mountpoint -q "$USB_PATH" || {
    echo "USB drive not mounted at $USB_PATH. Trying to mount..."
    mount "$USB_PATH" 2>/dev/null || {
      echo "Failed to mount USB. Check 'block info' and 'mount'"
      return 1
    }
  }

  mkdir -p "$DATA_DIR"

  procd_open_instance
  procd_set_param command "$BIN"
  procd_set_param env STALKERHEK_BIND_ADDR="0.0.0.0:9900"
  procd_set_param env RUST_LOG=info
  procd_set_param work "$STALKERHEK_DIR"
  # Restart on crash
  procd_set_param respawn 5 10 0
  # Basic stdout/stderr logging
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance

  echo "Stalkerhek started (PID in procd). Web UI at http://this-router:9900/dashboard"
}

stop_service() {
  procd_close_instance 2>/dev/null || true
  echo "Stalkerhek stopped."
}

service_triggers() {
  procd_add_reload_trigger "stalkerhek"
}
